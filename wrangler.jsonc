{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "deepseek-codex-adapter",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-19",
  "compatibility_flags": ["enable_request_signal", "request_signal_passthrough"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
}
